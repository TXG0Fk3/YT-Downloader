<?xml version="1.0" encoding="utf-8" ?>
<ContentDialog x:Class="YT_Downloader.Views.Dialogs.DetailsDialog"
               xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
               xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
               xmlns:converters="using:YT_Downloader.Helpers.UI.Converters"
               xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
               xmlns:local="using:YT_Downloader.Views.Dialogs"
               xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
               Title="Add New Download"
               CloseButtonText="Cancel"
               DefaultButton="Primary"
               IsPrimaryButtonEnabled="{x:Bind ViewModel.IsDownloadEnabled, Mode=OneWay}"
               PrimaryButtonCommand="{x:Bind ViewModel.DownloadCommand}"
               PrimaryButtonText="Download"
               Style="{StaticResource DefaultContentDialogStyle}"
               mc:Ignorable="d">
    <ContentDialog.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <converters:BooleanNegationConverter x:Key="BooleanNegationConverter" />
    </ContentDialog.Resources>

    <Grid Width="324" RowDefinitions="Auto, Auto, Auto" RowSpacing="12">
        <Grid.ChildrenTransitions>
            <TransitionCollection>
                <RepositionThemeTransition />
            </TransitionCollection>
        </Grid.ChildrenTransitions>

        <!--  URL Section  -->
        <Grid Grid.Row="0" ColumnDefinitions="*, 38">
            <TextBox Grid.Column="0"
                     Height="62"
                     Header="Enter your YT video/playlist URL:"
                     IsSpellCheckEnabled="False"
                     KeyDown="UrlTextBox_KeyDown"
                     Text="{x:Bind ViewModel.UrlBoxText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     ToolTipService.ToolTip="Type your YT video/playlist URL and press Enter button" />
            <Button Grid.Column="1"
                    Width="35"
                    Height="35"
                    Padding="0"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Command="{x:Bind ViewModel.LoadContentInfoCommand}"
                    Style="{StaticResource AccentButtonStyle}"
                    ToolTipService.ToolTip="Load Video Info">
                <FontIcon Glyph="&#xE8FB;" />
            </Button>
        </Grid>

        <!--  Video Info and Download Preferences  -->
        <Grid Grid.Row="1"
              RowDefinitions="Auto, Auto, Auto, Auto"
              RowSpacing="8"
              Visibility="{x:Bind ViewModel.IsContentVisible, Converter={StaticResource BooleanToVisibilityConverter}, Mode=OneWay}">
            <HyperlinkButton Grid.Row="0"
                             Padding="4"
                             HorizontalAlignment="Center"
                             Content="{x:Bind ViewModel.Title, Mode=OneWay}"
                             NavigateUri="{Binding ContentUrl, Mode=OneWay}"
                             ToolTipService.ToolTip="Open Video in Browser" />

            <Grid Grid.Row="1" ColumnDefinitions="*, 104" ColumnSpacing="6">
                <Grid Grid.Column="0" Background="{ThemeResource AcrylicBackgroundFillColorBaseBrush}" CornerRadius="6">
                    <Image Source="{Binding ThumbnailUrl, Mode=OneWay}" Stretch="Fill" Visibility="{x:Bind ViewModel.IsContentLoading, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Invert, Mode=OneWay}" />
                    <ProgressRing HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="{x:Bind ViewModel.IsContentLoading, Mode=OneWay}" />
                    <FontIcon HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              FontSize="32"
                              Glyph="&#xEA69;"
                              Visibility="{x:Bind ViewModel.IsPlaylistIconVisible, Converter={StaticResource BooleanToVisibilityConverter}, Mode=OneWay}" />
                </Grid>

                <Grid Grid.Column="1" RowDefinitions="Auto, Auto" RowSpacing="6">
                    <ComboBox Grid.Row="0"
                              HorizontalAlignment="Stretch"
                              Header="Format"
                              IsEnabled="{x:Bind ViewModel.IsContentLoading, Converter={StaticResource BooleanNegationConverter}, Mode=OneWay}"
                              ItemsSource="{x:Bind ViewModel.AvailableFormats, Mode=OneWay}"
                              SelectedItem="{x:Bind ViewModel.SelectedFormat, Mode=TwoWay}" />
                    <ComboBox Grid.Row="1"
                              HorizontalAlignment="Stretch"
                              Header="Quality"
                              IsEnabled="{x:Bind ViewModel.IsQualitySelectionEnabled, Mode=OneWay}"
                              ItemsSource="{x:Bind ViewModel.AvailableQualities, Mode=OneWay}"
                              SelectedValue="{x:Bind ViewModel.SelectedQuality, Mode=TwoWay}" />
                </Grid>
            </Grid>

            <TextBox Grid.Row="2"
                     Grid.Column="0"
                     Height="62"
                     Header="File Name:"
                     IsEnabled="{x:Bind ViewModel.IsFileNameBoxEnabled, Mode=OneWay}"
                     PlaceholderText="{x:Bind ViewModel.DefaultFileName, Mode=OneWay}"
                     Text="{x:Bind ViewModel.UserFileName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

            <TextBlock Grid.Row="3">
                <Run>File Size:</Run>
                <LineBreak />
                <Run Foreground="DarkGray" Text="{x:Bind ViewModel.SizeMB, Mode=OneWay}" />
            </TextBlock>
        </Grid>

        <!--  Error&Warnings InfoBar  -->
        <InfoBar Title="Error"
                 Grid.Row="2"
                 IsClosable="false"
                 IsOpen="True"
                 Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                 Severity="Error"
                 Visibility="{x:Bind ViewModel.IsErrorVisible, Converter={StaticResource BooleanToVisibilityConverter}, Mode=OneWay}" />
    </Grid>
</ContentDialog>
